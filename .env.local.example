# Copy this file to .env and fill in your values before running.
# Never commit .env to version control.

# ── Site ──────────────────────────────────────────────────────────────────
# Public URL of the site (no trailing slash)
NEXT_PUBLIC_SITE_URL=https://codersdiary.online

# ── Stripe Payment Links ────────────────────────────────────────────────
# Stripe Payment Links are pre-created in your Stripe Dashboard and stored
# directly in data/courses.ts — no secret keys are needed here.
# TODO(security): If you later add a backend checkout API, add:
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
